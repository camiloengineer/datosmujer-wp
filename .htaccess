# ============================================================
# BEGIN Hardening datosmujer.cl (seguridad)
# Bloque aditivo, fuera de los marcadores autogestionados (WPSC/WordPress/cPanel/Wordfence).
# Revertir = borrar este bloque completo y re-deployar.
# ============================================================

# --- B1: bloquear xmlrpc.php (sin Jetpack/app movil; corta fuerza bruta y system.multicall) ---
<Files "xmlrpc.php">
<IfModule mod_authz_core.c>
	Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
	Order deny,allow
	Deny from all
</IfModule>
</Files>

# --- B4: directory listing + archivos sensibles ---
Options -Indexes

<Files "wp-config.php">
<IfModule mod_authz_core.c>
	Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
	Order deny,allow
	Deny from all
</IfModule>
</Files>

<Files "wp-config-sample.php">
<IfModule mod_authz_core.c>
	Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
	Order deny,allow
	Deny from all
</IfModule>
</Files>

<Files "readme.html">
<IfModule mod_authz_core.c>
	Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
	Order deny,allow
	Deny from all
</IfModule>
</Files>

<Files "license.txt">
<IfModule mod_authz_core.c>
	Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
	Order deny,allow
	Deny from all
</IfModule>
</Files>

# Dumps/logs/backups por extension. SIN token 'gz' generico:
# matcharia el index-https.html.gz de la cache WPSC -> 403 -> caeria el
# serving estatico -> regresion al 508. (Hallazgo de la verificacion adversarial.)
<FilesMatch "\.(sql|log|bak|old|orig|save|swp|swo|tmp|dump|tar|tgz|zip)$">
<IfModule mod_authz_core.c>
	Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
	Order deny,allow
	Deny from all
</IfModule>
</FilesMatch>

# Dumps comprimidos por nombre COMPLETO: matchea backup.sql.gz / archivo.tar.gz
# pero NUNCA index-https.html.gz de la cache.
<FilesMatch "\.(sql|tar)\.gz$">
<IfModule mod_authz_core.c>
	Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
	Order deny,allow
	Deny from all
</IfModule>
</FilesMatch>

# --- B3: headers de seguridad (HSTS SIN includeSubDomains por mail.datosmujer.cl; SIN CSP) ---
<IfModule mod_headers.c>
	Header always set X-Content-Type-Options "nosniff"
	Header always set X-Frame-Options "SAMEORIGIN"
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
	Header always set Strict-Transport-Security "max-age=31536000"
</IfModule>

# ============================================================
# END Hardening datosmujer.cl (seguridad)
# ============================================================
